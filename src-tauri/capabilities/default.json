{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for stroygetter-native",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        { "name": "yt-dlp", "sidecar": true },
        { "name": "ffmpeg", "sidecar": true }
      ]
    },
    "opener:allow-open-path",
    "dialog:allow-open",
    "log:default"
  ]
}
